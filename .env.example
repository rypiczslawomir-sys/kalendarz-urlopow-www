# Port (domyślnie 5175 lokalnie; na hostingu ustawia platforma, np. PORT=10000)
PORT=5175

# Logowanie — ZMIEŃ przed wystawieniem do internetu!
AUTH_USER=admin
AUTH_PASSWORD=1947

# Losowy długi ciąg — wygeneruj np.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=zmien-na-losowy-ciag-minimum-32-znaki

# production na Render/Railway — włącza secure cookie (HTTPS)
NODE_ENV=production
